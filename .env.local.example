# Frontend Environment Configuration
# =====================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to create your local environment file:
#    cp .env.local.example .env.local
#
# 2. Update the values in .env.local with your specific settings
#
# 3. The .env.local file is git-ignored and will NOT be committed
#    Never commit sensitive information like API keys or tokens
#
# NOTE: This file (.env.local.example) is committed to version control
#       as a template and reference for developers.
#       Your actual configuration goes in .env.local (git-ignored).
#
# =====================================

# API Base URL for backend requests
# Development: local backend server
# Production: actual API endpoint
VITE_API_URL=http://localhost:5000/api
